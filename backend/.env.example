# Database
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/secure_files?schema=public"

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_jwt_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_here_change_in_production
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# File Upload
MAX_FILE_SIZE=52428800        # 50MB in bytes